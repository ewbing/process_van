{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "process_van: Hogwarts sample",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/process_van.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "--fixed",
                "--csv-path",
                "${workspaceFolder}/hogwarts_test/Hogwarts-DataExport.csv"
            ]
        },
        {
            "name": "process_van: Vanguard download",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/process_van.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "--fixed",
                "--csv-path",
                "${env:HOME}/allocations/Downloads/PortfolioWatchData.csv"
            ]
        }
    ]
}
